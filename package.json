{
  "name": "@gr/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --fix && npm run typecheck",
    "lint:check": "eslint . && npm run typecheck",
    "test": "node --import tsx --test src/**/*.test.ts",
    "migrate:roles": "tsx src/scripts/migrateOrganizationRoleModel.ts",
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.3",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.5",
    "fastify": "^5.9.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.7.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.16.5",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.1"
  }
}

API_PORT=4000
# Optional platform override. Render and similar platforms inject PORT
# automatically; src/server.ts prefers PORT over API_PORT when present.
# PORT=10000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=ia_session
# Use none when frontend and API are on different sites. none requires HTTPS.
AUTH_COOKIE_SAME_SITE=lax
# Optional override. Leave unset to default to true in production and false in local dev.
# AUTH_COOKIE_SECURE=true
# Safety valve for exceptional cases only. Real production should use FILE_STORAGE_DRIVER=s3.
# For the lowest-risk MVP on a single Render backend with a persistent disk,
# set this to true explicitly and keep the backend at one instance.
# ALLOW_LOCAL_FILE_STORAGE_IN_PRODUCTION=true
CORS_ORIGIN=http://localhost:8080
WEBAPP_URL=http://localhost:8080
PYTHON_SERVICE_URL=http://localhost:8100
# Must match ia_python_service's INTERNAL_SERVICE_TOKEN exactly.
# Generate a real value with: openssl rand -hex 32
PYTHON_SERVICE_SHARED_SECRET=
PYTHON_SERVICE_TIMEOUT_MS=30000
PYTHON_ANALYTICS_TIMEOUT_MS=120000
FILE_STORAGE_DRIVER=local
# For the MVP Render setup, point this at the persistent disk mount path, for
# example /opt/render/project/src/uploads.
UPLOAD_DIR=./uploads
# Required when FILE_STORAGE_DRIVER=s3
# Example endpoints:
# AWS S3: https://s3.eu-central-1.amazonaws.com
# Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
# MinIO: http://minio:9000
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# Optional prefix within the bucket, for example: impact-atlas
# S3_KEY_PREFIX=
# Optional. Defaults to true, which is the safest setting for MinIO/R2.
# Set to false for virtual-host-style providers if needed.
# S3_FORCE_PATH_STYLE=true
#
# Local MinIO verification example:
# FILE_STORAGE_DRIVER=s3
# S3_ENDPOINT=http://minio:9000
# S3_REGION=us-east-1
# S3_BUCKET=impact-atlas-local
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_KEY_PREFIX=backend-assets
# S3_FORCE_PATH_STYLE=true
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=impact_atlas_backend
# disabled (default) sends no real email and needs no further config below —
# fine for local dev. Switch to mailersend and fill in MAILERSEND_API_TOKEN
# once you actually need invitation/notification emails to go out.
EMAIL_PROVIDER=disabled
EMAIL_FROM=noreply@example.org
EMAIL_FROM_NAME=Impact Atlas
# EMAIL_REPLY_TO=replies@example.org
# EMAIL_REPLY_TO_NAME=Impact Atlas Support
MAILERSEND_API_BASE_URL=https://api.mailersend.com/v1
# Required when EMAIL_PROVIDER=mailersend.
MAILERSEND_API_TOKEN=
AI_PROVIDER=mock
AI_MODEL=mock-structured-v1
